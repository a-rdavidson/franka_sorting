    <model name="red_block3"><pose>0.4 0 0.40 0 0 0</pose><link name="link"><inertial><mass>0.05</mass><inertia><ixx>0.000013</ixx><iyy>0.000013</iyy><izz>0.000013</izz></inertia></inertial><collision name="collision"><geometry><box><size>0.04 0.04 0.06</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.04 0.04 0.06</size></box></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual></link></model>
    <model name="blue_block3"><pose>0.4 0.2 0.40 0 0 0</pose><link name="link"><inertial><mass>0.05</mass><inertia><ixx>0.000013</ixx><iyy>0.000013</iyy><izz>0.000013</izz></inertia></inertial><collision name="collision"><geometry><box><size>0.04 0.04 0.06</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.04 0.04 0.06</size></box></geometry><material><ambient>0 0 1 1</ambient><diffuse>0 0 1 1</diffuse></material></visual></link></model>

